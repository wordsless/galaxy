    ],
    "constraints":
    [],
    "generation_parameters":
    {
        "temperature": 0.2,
        "top_p": 1.0,
        "max_tokens": 500,
        "presence_penalty": 0.0,
        "frequency_penalty": 0.0,
        "n": 1,
        "stream": false,
        "echo": false,
        "seed": 0,
        "bestOf": 1,
        "logitBias":
        {}
    }
}