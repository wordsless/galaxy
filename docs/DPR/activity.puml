@startuml DPR_Algorithm_Full_Activity_Diagram
start
partition "DPR 稠密检索整体流程" {
    fork
        partition "阶段1：训练阶段 Training" {
            :初始化模型;
            :构建Query Encoder(BERT);
            :构建Context Encoder(BERT);
            :两编码器权重独立不共享;

            :构建训练样本集;
            :Question q(用户问题);
            :Positive Passage p+(正样本段落);
            :Negative Passages p-(负样本段落);

            :前向编码计算向量;
            :q → QueryEncoder → 向量q;
            :p+/p- → ContextEncoder → 向量p+/p-;

            :计算相似度(点积);
            :sim(q,p+) = q·p+;
            :sim(q,p-) = q·p-;

            :计算多分类负对数似然损失;
            note right: L = -log(exp(q·p+)/∑exp(q·pᵢ))
            :反向传播更新参数;
            :更新QueryEncoder权重;
            :更新ContextEncoder权重;

            if (模型收敛?) then (否)
                :回到前向编码;
            else (是)
                :保存训练好的双编码器;
            endif
        }
    fork again
        partition "阶段2：推理/检索阶段 Inference" {
            partition "离线建索引(一次性)" {
                :加载训练后ContextEncoder;
                :遍历全部文档段落;
                :段落→ContextEncoder→文档向量;
                :文档向量存入向量库(FAISS/Milvus);
                :构建ANN向量索引(HNSW/IVF);
            }

            partition "在线实时检索" {
                :接收用户原始查询raw query;
                :raw query → QueryEncoder → 查询向量q;
                :向量库ANN近似最近邻检索;
                :计算q与所有文档向量相似度;
                :按相似度降序排序;
                :筛选Top‑K相关段落;
                :输出Retrieved Passages(检索文档集);
                :送入LLM作为RAG上下文;
            }
        }
    endfork
}
end
@enduml